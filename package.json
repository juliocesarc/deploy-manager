{
  "name": "deploy-manager",
  "version": "1.0.0",
  "description": "Agnostic webhook-based deploy manager using docker compose",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "migrate": "node dist/models/migrate.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-loki": "^2.2.3",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
