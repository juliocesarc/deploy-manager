# ─── Application ──────────────────────────────────────────────────────────────
DOMAIN=deploy.example.com
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://deploy:change-me@postgres:5432/deployments
POSTGRES_PASSWORD=change-me

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Paths ────────────────────────────────────────────────────────────────────
PROJECTS_DIR=/projects
BACKUPS_DIR=/data/backups

# ─── Health check defaults ────────────────────────────────────────────────────
DEFAULT_HEALTH_CHECK_TIMEOUT=60
DEFAULT_HEALTH_CHECK_INTERVAL=2000

# ─── Traefik / TLS ────────────────────────────────────────────────────────────
# Email used for Let's Encrypt registration
ACME_EMAIL=admin@example.com

# ─── Observability (optional) ─────────────────────────────────────────────────
# Leave blank to disable Loki transport
LOKI_HOST=http://loki:3100
# LOKI_BASIC_AUTH=user:password
